<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Minimal .NET Framework (net48) System.Web + ASP.NET Web API host that exercises
    Microsoft.Identity.Web's App Service managed identity token acquisition.
    SDK-style (so it builds with the repo's pinned .NET SDK) but still targets net48
    to cover the .NET Framework code path. The App Service deploy package is assembled
    by the pipeline, so the ASP.NET Core Web SDK is intentionally not used.
  -->
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>ManagedIdentityWebApp</RootNamespace>
    <AssemblyName>ManagedIdentityWebApp</AssemblyName>
    <Nullable>disable</Nullable>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System.Web" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNet.WebApi.Core" Version="5.2.7" />
    <PackageReference Include="Microsoft.AspNet.WebApi.WebHost" Version="5.2.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Microsoft.Identity.Web.TokenAcquisition\Microsoft.Identity.Web.TokenAcquisition.csproj" />
    <ProjectReference Include="..\..\..\..\src\Microsoft.Identity.Web.DownstreamApi\Microsoft.Identity.Web.DownstreamApi.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Global.asax">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Web.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
