{
    "AzureAd": {
        "Instance": "https://login.microsoftonline.com/",
        "TenantId": "bea21ebe-8b64-4d06-9f6d-6a889b120a7c",
        "ClientId": "163ffef9-a313-45b4-ab2f-c7e2f5e0e23e",
        "AzureRegion": "westus3",
        "ClientCapabilities": [ "cp1" ],
        "ClientCredentials": [
            {
                "SourceType": "CustomSignedAssertion",
                "CustomSignedAssertionProviderName": "OidcIdpSignedAssertion",
                "CustomSignedAssertionProviderData": {
                    "ConfigurationSection": "OidcFicIdp"
                }
            }
        ]
    },

    // Self-FIC: outer and inner are the same app + same cert. This is the MSI team's
    // ESTS-allowlisted-for-mtls_pop app (same coordinates the working OidcFic_WithMtlsPop
    // E2E test used). The LabAuth cert authenticates the inner-leg AND is the binding key
    // that pins the outer Entra token via mTLS PoP.
    //   - Entry 1 (no UseBoundCredential)         : inner-leg auth to the external OIDC IdP
    //   - Entry 2 (UseBoundCredential = true)     : binding cert resolved by our spike loader;
    //                                               marked Skip=true so the inner leg can't pick it
    "OidcFicIdp": {
        "Instance": "https://login.microsoftonline.com/",
        "TenantId": "bea21ebe-8b64-4d06-9f6d-6a889b120a7c",
        "ClientId": "163ffef9-a313-45b4-ab2f-c7e2f5e0e23e",
        "AzureRegion": "westus3",
        "SendX5C": true,
        "ClientCredentials": [
            {
                "SourceType": "StoreWithDistinguishedName",
                "CertificateStorePath": "CurrentUser/My",
                "CertificateDistinguishedName": "CN=LabAuth.MSIDLab.com"
            },
            {
                "SourceType": "StoreWithDistinguishedName",
                "CertificateStorePath": "CurrentUser/My",
                "CertificateDistinguishedName": "CN=LabAuth.MSIDLab.com",
                "UseBoundCredential": true
            }
        ]
    },

    "DownstreamApi": {
        "BaseUrl": "https://graph.microsoft.com/",
        "RelativePath": "v1.0/applications/$count",
        "RequestAppToken": true,
        "ProtocolScheme": "MTLS_POP",
        "Scopes": [ "https://graph.microsoft.com/.default" ]
    },

    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft": "Information"
        }
    }
}
